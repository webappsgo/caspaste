{{define "titlePrefix"}}Paste List | {{end}}
{{define "headAppend"}}{{end}}
{{define "article"}}
<h3>Recent Pastes</h3>

{{if .Pastes}}
<div class="paste-list-container">
	<table class="paste-list-table">
		<thead>
			<tr>
				<th>Title</th>
				<th>Language</th>
				<th>Created</th>
			</tr>
		</thead>
		<tbody>
		{{range .Pastes}}
			<tr>
				<td><a href="/{{.ID}}">{{if .Title}}{{.Title}}{{else}}Untitled{{end}}</a></td>
				<td>{{.Syntax}}</td>
				<td>{{.CreateTimeStr}}</td>
			</tr>
		{{end}}
		</tbody>
	</table>
</div>

<div class="pagination">
	{{if .HasPrev}}<a href="/list?limit={{.Limit}}&offset={{.PrevOffset}}" class="pagination-link">&larr; Previous</a>{{end}}
	{{if and .HasPrev .HasNext}}<span class="pagination-separator">|</span>{{end}}
	{{if .HasNext}}<a href="/list?limit={{.Limit}}&offset={{.NextOffset}}" class="pagination-link">Next &rarr;</a>{{end}}
</div>
{{else}}
<div class="empty-state">
	<svg class="empty-state-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
		<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
		<polyline points="14 2 14 8 20 8"/>
		<line x1="16" y1="13" x2="8" y2="13"/>
		<line x1="16" y1="17" x2="8" y2="17"/>
		<polyline points="10 9 9 9 8 9"/>
	</svg>
	<h3 class="empty-state-title">{{ call .Translate `list.NoPastes` }}</h3>
	<p class="empty-state-message">{{ call .Translate `list.NoPastesMessage` }}</p>
	<a href="/" class="btn-primary">{{ call .Translate `list.CreateFirst` }}</a>
</div>
{{end}}

{{end}}
