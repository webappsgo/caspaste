<h4 id="powershell">PowerShell function</h4>

<p>Add to your <code>$PROFILE</code> (<code>Microsoft.PowerShell_profile.ps1</code>).
Supports pipeline input, file upload, and inline text.</p>

{{ call .Highlight `# ── CasPaste PowerShell function ─────────────────────────────
function Paste {
    [CmdletBinding()]
    param(
        [Parameter(Position = 0)]
        [string]$File,

        [string]$Syntax = ($env:CASPASTE_SYNTAX ?? "autodetect"),
        [string]$Title  = ($env:CASPASTE_TITLE  ?? ""),
        [string]$Url    = ($env:CASPASTE_URL     ?? "https://your-server")
    )
    begin   { $lines = [System.Collections.Generic.List[string]]::new() }
    process { if ($null -ne $_) { $lines.Add([string]$_) } }
    end {
        $nl      = [char]10
        $headers = @{ Accept = "application/json" }

        if ($File) {
            # Binary-safe file upload
            $form = @{ file = Get-Item $File; syntax = $Syntax }
            if ($Title) { $form.title = $Title }
        } elseif ($lines.Count -gt 0) {
            # Pipeline or inline text
            $form = @{ body = ($lines -join $nl); syntax = $Syntax }
            if ($Title) { $form.title = $Title }
        } else {
            Write-Error "Provide -File or pipe text to Paste"
            return
        }

        $callArgs = @{
            Uri     = "$Url/api/v1/pastes"
            Method  = "POST"
            Form    = $form
            Headers = $headers
        }
        (Invoke-RestMethod @callArgs).data.url
    }
}
# ──────────────────────────────────────────────────────────────` "powershell" }}

<h5>Usage examples</h5>
{{ call .Highlight `# Set your server (add to $PROFILE)
$env:CASPASTE_URL = "https://your-server"

# Pipe command output
git diff | Paste
Get-Content app.log | Paste

# Upload a file (text or binary)
Paste -File screenshot.png
Paste -File report.pdf -Title "Monthly Report"

# Inline text
"quick note" | Paste

# Override syntax
Paste -File main.go -Syntax go` "powershell" }}


<h4 id="envvars">Environment variables</h4>

<table>
	<tr>
		<th>Variable</th>
		<th>Default</th>
		<th>Description</th>
	</tr>
	<tr>
		<td><code>CASPASTE_URL</code></td>
		<td><em>(required)</em></td>
		<td>Base URL of your CasPaste server, e.g. <code>{{.ServerURL}}</code></td>
	</tr>
	<tr>
		<td><code>CASPASTE_SYNTAX</code></td>
		<td><code>autodetect</code></td>
		<td>Default syntax for text pastes. Any value from <a href="/api/v1/server/info"><code>/api/v1/server/info</code></a> <code>syntaxes</code> list, or <code>autodetect</code>.</td>
	</tr>
	<tr>
		<td><code>CASPASTE_TITLE</code></td>
		<td><em>empty</em></td>
		<td>Default title applied to every paste created by the shell function.</td>
	</tr>
</table>
{{end}}
