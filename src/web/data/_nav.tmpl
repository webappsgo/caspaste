{{define "nav"}}
		<nav role="navigation" aria-label="Main navigation">
			<a href="/" class="site-title" aria-label="CasPaste home">{{ call .Translate `base.CasPaste` }}</a>
			<input type="checkbox" id="nav-toggle-state" class="nav-toggle-checkbox" aria-hidden="true">
			<label for="nav-toggle-state" class="nav-toggle" aria-label="Toggle navigation menu">
				<span class="nav-toggle-icon"></span>
			</label>
			<div class="nav-links">
				<a href="/list" aria-label="View paste list">{{ call .Translate `base.List` }}</a>
				<a href="/server/about" aria-label="About CasPaste">{{ call .Translate `base.About` }}</a>
				<a href="/docs" aria-label="Documentation">{{ call .Translate `base.Docs` }}</a>
				<input type="checkbox" id="history-popup-state" class="history-popup-checkbox" aria-hidden="true">
				<label for="history-popup-state" class="nav-button" aria-label="View paste history">{{ call .Translate `base.History` }}</label>
				<a href="/settings" aria-label="Settings">{{ call .Translate `base.Settings` }}</a>
			</div>

			{{/* Header Actions - Notification Bell + Profile (Per AI.md PART 16, PART 34) */}}
			<div class="header-actions">
				{{if .User}}
				{{/* Notification Bell - Required when PART 34 implemented */}}
				<div class="notification-bell" aria-label="Notifications">
					<button type="button" class="bell-button" id="js-notification-bell" aria-haspopup="true" aria-expanded="false" aria-label="{{if .UnreadCount}}{{.UnreadCount}} unread notifications{{else}}Notifications{{end}}">
						<svg class="bell-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
							<path d="M13.73 21a2 2 0 0 1-3.46 0"/>
						</svg>
						{{if .UnreadCount}}<span class="notification-badge" aria-label="{{.UnreadCount}} unread">{{if gt .UnreadCount 9}}9+{{else}}{{.UnreadCount}}{{end}}</span>{{end}}
					</button>
					<div class="notification-dropdown" id="js-notification-dropdown" role="menu" hidden>
						<div class="dropdown-header">
							<span>{{ call .Translate `notifications.Title` }}</span>
							<button type="button" class="mark-all-read" id="js-mark-all-read">{{ call .Translate `notifications.MarkAllRead` }}</button>
						</div>
						<div class="notification-list" id="js-notification-list">
							{{if .Notifications}}
							{{range .Notifications}}
							<a href="{{.Link}}" class="notification-item{{if not .Read}} unread{{end}}" data-notification-id="{{.ID}}">
								{{if not .Read}}<span class="notification-dot"></span>{{end}}
								<span class="notification-icon">{{.Icon}}</span>
								<div class="notification-content">
									<span class="notification-title">{{.Title}}</span>
									<span class="notification-message">{{.Message}}</span>
									<span class="notification-time">{{.TimeAgo}}</span>
								</div>
							</a>
							{{end}}
							{{else}}
							<div class="empty-state empty-state-padded">
								<p class="empty-state-message">{{ call .Translate `notifications.None` }}</p>
							</div>
							{{end}}
						</div>
						<a href="/users/notifications" class="dropdown-footer">{{ call .Translate `notifications.ViewAll` }}</a>
					</div>
				</div>

				{{/* Profile Icon - Required when PART 34 implemented */}}
				<div class="profile-menu" aria-label="User menu">
					<button type="button" class="profile-button" id="js-profile-button" aria-haspopup="true" aria-expanded="false">
						{{if .User.AvatarURL}}
						<img src="{{.User.AvatarURL}}" alt="{{.User.Username}}" class="avatar">
						{{else}}
						<svg class="avatar" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
							<circle cx="12" cy="8" r="4"/>
							<path d="M20 21a8 8 0 0 0-16 0"/>
						</svg>
						{{end}}
						<svg class="dropdown-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="12" height="12">
							<polyline points="6 9 12 15 18 9"/>
						</svg>
					</button>
					<div class="profile-dropdown" id="js-profile-dropdown" role="menu" hidden>
						<div class="dropdown-header">
							<span class="username">{{.User.Username}}</span>
						</div>
						<a href="/users" class="dropdown-item" role="menuitem">{{ call .Translate `profile.Profile` }}</a>
						<a href="/users/settings" class="dropdown-item" role="menuitem">{{ call .Translate `profile.Settings` }}</a>
						<a href="/users/security" class="dropdown-item" role="menuitem">{{ call .Translate `profile.Security` }}</a>
						<a href="/users/tokens" class="dropdown-item" role="menuitem">{{ call .Translate `profile.APITokens` }}</a>
						<div class="dropdown-divider" role="separator"></div>
						<div class="dropdown-item theme-toggle">
							{{ call .Translate `profile.Theme` }}:
							<button type="button" data-theme="dark">{{ call .Translate `theme.Dark` }}</button> |
							<button type="button" data-theme="light">{{ call .Translate `theme.Light` }}</button> |
							<button type="button" data-theme="auto">{{ call .Translate `theme.Auto` }}</button>
						</div>
						<div class="dropdown-divider" role="separator"></div>
						<a href="/server/help" class="dropdown-item" role="menuitem">{{ call .Translate `profile.Help` }}</a>
						<form action="/server/auth/logout" method="POST" class="logout-form">
							<input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
							<button type="submit" class="dropdown-item logout" role="menuitem">{{ call .Translate `profile.SignOut` }}</button>
						</form>
					</div>
				</div>
				{{else}}
				{{/* Login/Register links — only shown when multi-user is enabled */}}
				{{if .ShowLogin}}<a href="/server/auth/login" class="nav-button">{{ call .Translate `auth.Login` }}</a>{{end}}
				{{if .ShowRegister}}<a href="/server/auth/register" class="nav-button">{{ call .Translate `auth.Register` }}</a>{{end}}
				{{end}}
			</div>
		</nav>
{{end}}
