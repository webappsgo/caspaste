{{define "titlePrefix"}}Login | {{end}}
{{define "headAppend"}}{{end}}
{{define "article"}}
<div class="login-container">
	<div class="login-header">
		<div class="login-icon">🔐</div>
		<h1>{{ call .Translate `login.Title` }}</h1>
		<p>{{ call .Translate `login.Subtitle` }}</p>
	</div>

	{{if .Error}}
	<div class="login-error">
		{{ call .Translate `login.Error` }}
	</div>
	{{end}}

	<form class="login-form" action="/login" method="post">
		<input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
		<input type="hidden" name="redirect" value="{{.Redirect}}">

		<div class="form-group">
			<label for="username">{{ call .Translate `login.Username` }}</label>
			<input
				type="text"
				id="username"
				name="username"
				placeholder="{{ call .Translate `login.UsernamePlaceholder` }}"
				autocomplete="username"
				autofocus
				required
			>
		</div>

		<div class="form-group">
			<label for="password">{{ call .Translate `login.Password` }}</label>
			<input
				type="password"
				id="password"
				name="password"
				placeholder="{{ call .Translate `login.PasswordPlaceholder` }}"
				autocomplete="current-password"
				required
			>
		</div>

		<button type="submit" class="button-green">{{ call .Translate `login.Submit` }}</button>
	</form>

	<div class="back-link">
		<a href="/server/about">{{ call .Translate `login.BackToAbout` }}</a>
	</div>
</div>
{{end}}
