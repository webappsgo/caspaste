<!DOCTYPE html>
<html lang="{{.Language}}">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
	<meta name="description" content="CasPaste - A simple, self-hosted paste sharing service">
	<meta name="color-scheme" content="light dark">
	<title>{{template "titlePrefix" .}}{{ call .Translate `base.CasPaste` }}</title>
	<link rel="stylesheet" href="/style.css?t={{call .Theme `theme.Name.en`}}">
	<link rel="icon" href="data:,">
	
	<!-- PWA Support -->
	<link rel="manifest" href="/manifest.json">
	<meta name="theme-color" content="{{call .Theme `color.Header`}}">
	<meta name="apple-mobile-web-app-capable" content="yes">
	<meta name="apple-mobile-web-app-status-bar-style" content="default">
	<meta name="apple-mobile-web-app-title" content="CasPaste">
	
	{{template "headAppend" .}}
</head>
<body>
	<a href="#main-content" class="skip-to-main">Skip to main content</a>

	{{template "header" .}}

	<main id="main-content" role="main">
		<article>{{template "article" .}}</article>
	</main>

	{{template "footer" .}}

	<!-- Toast notification container per AI.md PART 16 -->
	<div id="toast-container" aria-label="Notifications"></div>

	<!-- History popup - CSS-driven open/close via #history-popup-state checkbox -->
	<div class="history-popup" id="history-popup" role="dialog" aria-modal="true" aria-labelledby="history-popup-title">
		<label for="history-popup-state" class="history-popup-backdrop" aria-hidden="true"></label>
		<div class="history-popup-dialog">
			<div class="history-popup-header">
				<h4 class="popup-title" id="history-popup-title">{{ call .Translate `historyJS.History` }}</h4>
				<label for="history-popup-state" class="history-popup-close" aria-label="Close">&times;</label>
			</div>
			<hr>
			<div class="history-popup-controls" id="history-popup-controls">
				<label class="checkbox"><input id="js-history-popup-enable" type="checkbox">{{ call .Translate `historyJS.EnableHistory` }}</label>
				<span id="js-history-popup-clear" class="text-red">{{ call .Translate `historyJS.ClearHistory` }}</span>
			</div>
			<div class="history-popup-list-container" id="js-history-popup-list-div">
				<ul id="js-history-popup-list"></ul>
				<noscript><p>{{ call .Translate `historyJS.LocalStorageNotSupported1` }}</p></noscript>
			</div>
		</div>
	</div>
	<script src="/history.js"></script>
	<script src="/toast.js"></script>
	<script src="/nav.js"></script>
</body>
</html>
