# =============================================================================
# Development Image — same as production but binary runs in debug mode
# Tagged :devel
# =============================================================================

# =============================================================================
# Build Stage — Compile Go binary
# =============================================================================
FROM casjaysdev/go:latest AS builder

RUN apk add --no-cache git bash

ARG TARGETARCH
ARG VERSION=dev
ARG BUILD_DATE
ARG COMMIT_ID

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=${TARGETARCH} go build \
    -ldflags "-s -w \
      -X 'main.Version=${VERSION}' \
      -X 'main.CommitID=${COMMIT_ID}' \
      -X 'main.BuildDate=${BUILD_DATE}'" \
    -o /app/binary/caspaste ./src/server

RUN CGO_ENABLED=0 GOOS=linux GOARCH=${TARGETARCH} go build \
    -ldflags "-s -w \
      -X 'main.Version=${VERSION}' \
      -X 'main.CommitID=${COMMIT_ID}' \
      -X 'main.BuildDate=${BUILD_DATE}'" \
    -o /app/binary/caspaste-cli ./src/client

# =============================================================================
# Runtime Stage — Minimal Alpine image (development mode)
# =============================================================================
FROM alpine:latest

RUN apk add --no-cache \
    git \
    curl \
    bash \
    tini \
    tor

COPY --from=builder /app/binary/caspaste /usr/local/bin/caspaste
COPY --from=builder /app/binary/caspaste-cli /usr/local/bin/caspaste-cli
COPY docker/rootfs/ /
COPY docker/Dockerfile.dev /root/Dockerfile

RUN chmod 755 /usr/local/bin/*

# Development mode: DEBUG enabled, relaxed security
ENV MODE=development \
    TZ=America/New_York \
    DATABASE_DIR=/data/db/sqlite \
    DEBUG=true

EXPOSE 80

STOPSIGNAL SIGRTMIN+3

HEALTHCHECK --start-period=5m --interval=2m --timeout=15s --retries=3 \
    CMD /usr/local/bin/caspaste --status || exit 1

ENTRYPOINT [ "tini", "-p", "SIGTERM", "--", "/usr/local/bin/entrypoint.sh" ]
